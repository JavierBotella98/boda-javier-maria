# Copia este archivo como .env.local y rellena los valores reales.
# .env.local nunca se sube al repositorio (ver .gitignore).

# URL pública final del sitio (para metadatos y vista previa de WhatsApp)
NEXT_PUBLIC_SITE_URL=https://javierymaria2027.com

# Contraseña única para acceder a toda la web (invitados)
SITE_PASSWORD=

# Supabase (base de datos) — Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Panel de administración
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Notificación por email de nuevas confirmaciones (opcional, vía Resend)
RESEND_API_KEY=
ADMIN_NOTIFICATION_EMAIL=

# Cloudinary (galería de fotos, se configurará en la fase post-boda)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
